{
  "daemon": {
    "port": 7800,
    "api_key": "",
    "data_dir": "./data"
  },
  "scraper": {
    "dns": "cloudflare",
    "rutracker_cookie": "",
    "sources": [
      "yts", "1337x", "nyaa", "piratebay", 
      "fitgirl", "subsplease", "torrentscsv", "rutracker"
    ],
    "filters": {
      "language": "latino, castellano, multi-subs, es",
      "resolution": "1080p, 1080i",
      "min_seeders": "5"
    }
  },
  "torrent": {
    "download_dir": "/downloads",
    "auto_export_torrent": false,
    "max_download_rate": 0,
    "max_upload_rate": 0,
    "auto_cleanup": false,
    "seed_ratio": 1.5,
    "max_seed_days": 3,
    "hardlink_dir": "",
    "post_script": "",
    "watch_dir": "",
    "delete_files_on_stop": false,
    "trackers": [
      "udp://tracker.opentrackr.org:1337/announce"
    ],
    "category_dirs": {
      "movies": "/downloads/movies",
      "tvshows": "/downloads/tvshows"
    }
  },
  "rss": {
    "interval_min": 30,
    "feeds": [
      {
        "url": "https://nyaa.si/?page=rss&q=subsplease+1080p",
        "category": "tvshows",
        "regex": ["Arcane", "Solo Leveling"]
      }
    ]
  }
}
